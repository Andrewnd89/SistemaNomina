@{
    ViewData["Title"] = "Dashboard";
}

<h2 class="mb-4">Dashboard - Sistema de Nómina</h2>

<div class="row">
    <div class="col-md-3">
        <div class="card text-white bg-primary shadow mb-3">
            <div class="card-body text-center">
                <h1>@ViewBag.TotalEmpleados</h1>
                <p class="card-text">Empleados Activos</p>
                <a href="/Empleados" class="btn btn-light btn-sm">Ver todos</a>
            </div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="card text-white bg-success shadow mb-3">
            <div class="card-body text-center">
                <h1>@ViewBag.TotalDepartamentos</h1>
                <p class="card-text">Departamentos Activos</p>
                <a href="/Departamentos" class="btn btn-light btn-sm">Ver todos</a>
            </div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="card text-white bg-warning shadow mb-3">
            <div class="card-body text-center">
                <h1>@ViewBag.TotalSalarios</h1>
                <p class="card-text">Salarios Vigentes</p>
                <a href="/Salarios" class="btn btn-light btn-sm">Ver todos</a>
            </div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="card text-white bg-danger shadow mb-3">
            <div class="card-body text-center">
                <h1>@ViewBag.TotalTitulos</h1>
                <p class="card-text">Títulos Activos</p>
                <a href="/Titulos" class="btn btn-light btn-sm">Ver todos</a>
            </div>
        </div>
    </div>
</div>

<div class="row mt-4">
    <div class="col-md-12">
        <div class="card shadow">
            <div class="card-header bg-dark text-white">
                <h5>Accesos Rápidos</h5>
            </div>
            <div class="card-body">
                <a href="/Empleados/Crear" class="btn btn-primary m-1">+ Nuevo Empleado</a>
                <a href="/Departamentos/Crear" class="btn btn-success m-1">+ Nuevo Departamento</a>
                <a href="/Salarios/Crear" class="btn btn-warning m-1">+ Nuevo Salario</a>
                <a href="/Titulos/Crear" class="btn btn-danger m-1">+ Nuevo Título</a>
                <a href="/Reportes" class="btn btn-dark m-1">📊 Reportes</a>
            </div>
        </div>
    </div>
</div>