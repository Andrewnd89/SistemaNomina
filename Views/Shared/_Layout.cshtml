<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - SistemaNomina</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>
<body>
    <header>
        <nav class="navbar navbar-expand-sm navbar-dark bg-dark border-bottom mb-3">
            <div class="container-fluid">
                <a class="navbar-brand" href="/Home/Index">SistemaNomina</a>
                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target=".navbar-collapse">
                    <span class="navbar-toggler-icon"></span>
                </button>
                <div class="navbar-collapse collapse d-sm-inline-flex justify-content-between">
                    <ul class="navbar-nav flex-grow-1">
                        <li class="nav-item">
                            <a class="nav-link text-white" href="/Home/Index">Inicio</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link text-white" href="/Empleados">Empleados</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link text-white" href="/Departamentos">Departamentos</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link text-white" href="/Salarios">Salarios</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link text-white" href="/Titulos">Títulos</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link text-white" href="/Reportes">Reportes</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link text-white" href="/Auth/Logout">Cerrar Sesión</a>
                        </li>
                    </ul>
                </div>
            </div>
        </nav>
    </header>
    <div class="container">
        <main role="main" class="pb-3">
            @RenderBody()
        </main>
    </div>
    <footer class="border-top footer text-muted">
        <div class="container">
            &copy; 2026 - SistemaNomina
        </div>
    </footer>
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>