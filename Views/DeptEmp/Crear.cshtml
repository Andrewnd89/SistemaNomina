@model SistemaNomina.Models.DeptEmp
@{
    ViewData["Title"] = "Nueva Asignación";
}

<h2>Asignar Empleado a Departamento</h2>
<form method="post">
    <div class="mb-3">
        <label>Empleado</label>
        <select name="emp_no" class="form-control">
            @foreach (var e in ViewBag.Empleados)
            {
                <option value="@e.emp_no">@e.first_name @e.last_name</option>
            }
        </select>
    </div>
    <div class="mb-3">
        <label>Departamento</label>
        <select name="dept_no" class="form-control">
            @foreach (var d in ViewBag.Departamentos)
            {
                <option value="@d.dept_no">@d.dept_name</option>
            }
        </select>
    </div>
    <div class="mb-3">
        <label>Fecha Inicio</label>
        <input asp-for="from_date" type="date" class="form-control" />
    </div>
    <button type="submit" class="btn btn-success">Guardar</button>
    <a href="/DeptEmp" class="btn btn-secondary">Cancelar</a>
</form>